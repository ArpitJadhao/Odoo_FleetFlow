# ─────────────────────────────────────────
# FleetFlow — Root .gitignore
# ─────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment files — NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
build/
out/

# Prisma generated client
server/node_modules/
client/node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# TypeScript build info
*.tsbuildinfo
tsconfig.tsbuildinfo

# Prisma migrations lock (optional — keep migrations, ignore shadow db)
prisma/.env

# Vite cache
.vite/
